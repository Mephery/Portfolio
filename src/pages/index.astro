---
import '../styles/global.css';
import App from '../components/App';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Coline Derycke — Dev · Infra · Sécu</title>
		<meta name="description" content="Portfolio de Coline Derycke — développeuse BTS SIO en alternance, passionnée de dev full-stack, infrastructure et sécurité. Projet Chaos : chat E2EE chiffré avec WebRTC et Double Ratchet." />

		<!-- Open Graph (LinkedIn, Twitter, Discord…) -->
		<meta property="og:type"          content="website" />
		<meta property="og:title"         content="Coline Derycke — Dev · Infra · Sécu" />
		<meta property="og:description"   content="Développeuse BTS SIO · Projet Chaos (WebRTC, E2EE, Proxmox) · Three.js · Stormshield CSNA. Portfolio interactif." />
		<meta property="og:url"           content="https://www.colinederycke-portfolio.com/" />
		<meta property="og:image"         content="https://www.colinederycke-portfolio.com/og-image.png" />
		<meta property="og:image:width"   content="1917" />
		<meta property="og:image:height"  content="908" />
		<meta property="og:image:alt"     content="Portfolio interactif de Coline Derycke — Dev · Infra · Sécu" />
		<meta name="twitter:card"         content="summary_large_image" />
		<meta name="twitter:title"        content="Coline Derycke — Dev · Infra · Sécu" />
		<meta name="twitter:description"  content="Développeuse BTS SIO · Projet Chaos (WebRTC, E2EE, Proxmox) · Three.js · Stormshield CSNA." />
		<meta name="twitter:image"        content="https://www.colinederycke-portfolio.com/og-image.png" />
	</head>
	<body style="margin:0;padding:0;overflow:hidden;background:#000814;">
		<App client:only="react" />
	</body>
</html>